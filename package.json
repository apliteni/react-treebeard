{
  "name": "react-treebeard",
  "version": "3.2.4-modify",
  "description": "React Tree View Component",
  "main": "dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepare": "rimraf dist && babel src/ --out-dir dist/",
    "test": "jest --config=jest.config.js",
    "test:watch": "jest --config=jest.config.js --watch",
    "test:coverage": "jest --config=jest.config.js --coverage",
    "lint": "eslint .",
    "example": "webpack-dev-server --content-base ./example/ --config ./example/webpack.config.js",
    "build-example": "webpack --content-base ./example/ --config ./example/webpack.config.js --output ./dist/example.js"
  },
  "peerDependencies": {
    "@babel/runtime": ">=7.0.0",
    "@emotion/styled": "^10.0.10",
    "prop-types": ">=15.7.2",
    "react": ">=16.7.0",
    "react-dom": ">=16.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storybookjs/react-treebeard.git"
  },
  "keywords": [
    "react",
    "treeview",
    "data-driven",
    "customisable",
    "fast"
  ],
  "author": "Alex Curtis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/storybookjs/react-treebeard/issues"
  },
  "homepage": "https://github.com/storybooks/react-treebeard#readme",
  "devDependencies": {
    "@babel/cli": "^7.10.5",
    "@babel/core": "^7.11.4",
    "@babel/preset-env": "^7.11.0",
    "@babel/preset-react": "^7.10.4",
    "@babel/runtime": "^7.11.2",
    "@commitlint/cli": "^8.3.5",
    "@commitlint/travis-cli": "^8.3.5",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^24.9.0",
    "babel-loader": "^8.1.0",
    "babel-preset-react": "^6.24.1",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.3",
    "enzyme-to-json": "^3.5.0",
    "eslint": "^6.8.0",
    "eslint-loader": "^3.0.4",
    "eslint-plugin-react": "^7.20.6",
    "husky": "^3.1.0",
    "jest": "^24.9.0",
    "lodash": "^4.17.20",
    "prop-types": "^15.7.2",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-hot-loader": "^4.12.21",
    "rimraf": "^3.0.2",
    "webpack": "^4.44.1",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.0"
  },
  "dependencies": {
    "@emotion/core": "^10.0.35",
    "@emotion/styled": "^10.0.27"
  }
}
